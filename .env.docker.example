PANTRYLIST_MONGO_HOST_PORT=37917
PANTRYLIST_BACKEND_HOST_PORT=39173
PANTRYLIST_FRONTEND_HOST_PORT=48673

MONGO_INITDB_ROOT_USERNAME=pantrylist_root
MONGO_INITDB_ROOT_PASSWORD=change-this-root-password
MONGO_INITDB_DATABASE=pantrylist
MONGO_APP_DATABASE=pantrylist
MONGO_APP_USERNAME=pantrylist_app
MONGO_APP_PASSWORD=change-this-app-password
CORS_ORIGIN=http://localhost:48673
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_TIME_WINDOW=1 minute
RATE_LIMIT_TRUST_PROXY=false

# Cognito is disabled by default for local Docker boot until a real User Pool
# is configured. When enabled, register this callback in Cognito:
# http://localhost:48673/api/auth/cognito/callback
COGNITO_ENABLED=false
# COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
# COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
# COGNITO_CLIENT_ID=replace-with-cognito-client-id
# COGNITO_CLIENT_SECRET=
# COGNITO_REDIRECT_URI=http://localhost:48673/api/auth/cognito/callback
# COGNITO_LOGOUT_REDIRECT_URI=http://localhost:48673/login
COGNITO_SCOPES=openid email profile
COGNITO_ALLOWED_PROVIDERS=Google,Facebook,COGNITO
COGNITO_AUTH_TRANSACTION_TTL_SECONDS=900
AUTH_ACCESS_COOKIE_TTL_SECONDS=900
AUTH_REFRESH_COOKIE_TTL_SECONDS=2592000
