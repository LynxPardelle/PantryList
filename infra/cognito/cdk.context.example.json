{
  "projectName": "despensalista",
  "stage": "dev",
  "awsRegion": "us-east-1",
  "localFrontendBaseUrl": "http://localhost:48673",
  "productionFrontendBaseUrl": "https://despensalista.example.com",
  "domainPrefix": "despensalista-dev-your-suffix",
  "removalPolicy": "retain",
  "deletionProtection": "false",
  "enableGoogle": "true",
  "googleClientId": "replace-with-google-oauth-client-id",
  "googleClientSecretName": "/despensalista/dev/google-client-secret",
  "enableFacebook": "true",
  "facebookClientId": "replace-with-facebook-app-id",
  "facebookClientSecretName": "/despensalista/dev/facebook-client-secret",
  "facebookApiVersion": "v17.0",
  "includeServerlessBackend": "true",
  "serverlessFrontendBaseUrl": "https://dev.despensalista.example.com",
  "backendLambdaMemoryMb": "512",
  "backendLambdaTimeoutSeconds": "15"
}
