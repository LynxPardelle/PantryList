# Production-like Docker Compose / Dokploy example.
# Copy values into your deployment environment. Do not commit real secrets.

DATABASE_NAME=pantrylist
FRONTEND_PORT=48674

MONGO_INITDB_ROOT_USERNAME=pantrylist_root
MONGO_INITDB_ROOT_PASSWORD=replace-with-strong-root-password
MONGO_APP_USERNAME=pantrylist_app
MONGO_APP_PASSWORD=replace-with-strong-app-password

JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret

# Use true behind HTTPS. For local HTTP smoke testing only, set this to false.
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=pantrylist.example.com

CORS_ORIGIN=http://localhost:48674
BACKEND_URL=http://backend:3000
