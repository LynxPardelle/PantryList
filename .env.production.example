# Production-like Docker Compose / Dokploy example.
# Copy values into your deployment environment. Do not commit real secrets.

DATABASE_NAME=pantrylist
FRONTEND_PORT=48674

MONGO_INITDB_ROOT_USERNAME=pantrylist_root
MONGO_INITDB_ROOT_PASSWORD=replace-with-strong-root-password
MONGO_APP_USERNAME=pantrylist_app
MONGO_APP_PASSWORD=replace-with-strong-app-password

COGNITO_ENABLED=true
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=replace-with-cognito-client-id
# Optional. Set only if the Cognito app client is confidential.
COGNITO_CLIENT_SECRET=
COGNITO_REDIRECT_URI=http://localhost:48674/api/auth/cognito/callback
COGNITO_LOGOUT_REDIRECT_URI=http://localhost:48674/login
COGNITO_SCOPES=openid email profile
COGNITO_ALLOWED_PROVIDERS=Google,Facebook,COGNITO
COGNITO_AUTH_TRANSACTION_TTL_SECONDS=900
AUTH_ACCESS_COOKIE_TTL_SECONDS=900
AUTH_REFRESH_COOKIE_TTL_SECONDS=2592000

# Use true behind HTTPS. For local HTTP smoke testing only, set this to false.
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=pantrylist.example.com

CORS_ORIGIN=http://localhost:48674
BACKEND_URL=http://backend:3000
