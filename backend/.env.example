# Backend Environment Variables
# Copy this file to .env and update with your values

NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=mongodb://127.0.0.1:27017/pantrylist
DATABASE_NAME=pantrylist
# Docker local recommendation:
# DATABASE_URL=mongodb://pantrylist_app:change-this-app-password@127.0.0.1:27017/pantrylist?authSource=pantrylist

# API Configuration
API_PREFIX=api

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# Helmet Security Headers
HELMET_ENABLED=true

# Swagger Documentation
SWAGGER_ENABLED=true
SWAGGER_TITLE=PantryList API
SWAGGER_DESCRIPTION=API for managing household products and shopping schedules
SWAGGER_VERSION=1.0

# Notes
# Use a real MongoDB connection string for Dokploy or Atlas deployments.
